---
import "../styles/global.css";
import type { Locale } from "../lib/i18n";
import { getAltLangPath } from "../lib/i18n";

// Read site settings from site.json as fallback
const siteModule = await import("../data/site.json");
const site = siteModule.default || siteModule;

// Read footer data for structured data (phone, email, codes)
const footerModule = await import("../data/footer.json");
const footer = footerModule.default || footerModule;

interface Props {
  lang?: Locale;
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  lang = "fr",
  title = site.title || "Association d'Alphabétisation de Fatima — Trou-aux-Biches, Maurice",
  description = site.description || "Depuis 37 ans, nous aidons des enfants défavorisés à sortir de l'échec scolaire. Plus de 2 000 élèves ont pu retrouver le chemin de la confiance, de l'estime de soi et de la réussite.",
  canonicalPath,
  ogImage: ogImageProp,
  ogType = "website",
} = Astro.props;

const ogLocale = lang === "en" ? "en_US" : "fr_FR";
const ogImage = ogImageProp
  ? new URL(ogImageProp, Astro.url).href
  : new URL("/images/school-uodv3.jpg", Astro.url).href;
const baseUrl = new URL("/", Astro.url).href.replace(/\/$/, "");

// Dynamic canonical and hreflang URLs based on current page
const pagePath = canonicalPath ?? Astro.url.pathname;
const canonicalUrl = `${baseUrl}${pagePath}`;
const frPath = lang === "fr" ? pagePath : getAltLangPath(pagePath, "en", "fr");
const enPath = lang === "en" ? pagePath : getAltLangPath(pagePath, "fr", "en");
const frUrl = `${baseUrl}${frPath}`;
const enUrl = `${baseUrl}${enPath}`;
const ogLocaleAlt = lang === "en" ? "fr_FR" : "en_US";
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0e86b3" />
    <meta name="description" content={description} />

    <!-- Canonical + hreflang for bilingual SEO -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="fr" href={frUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={frUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Association d'Alphabétisation de Fatima" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Association d'Alphabétisation de Fatima — École à Trou-aux-Biches, Maurice" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />

    <!-- Preload LCP hero background -->
    <link rel="preload" as="image" type="image/webp" href="/images/fatima-hero-assembly.webp" fetchpriority="high" />

    <!-- Google Fonts (non-render-blocking) -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Open+Sans:wght@400;600&display=swap"
      media="print"
      onload="this.media='all'"
    />

    <!-- Font Awesome (non-render-blocking) -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
      integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Open+Sans:wght@400;600&display=swap" />
      <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    </noscript>

    <title>{title}</title>

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["EducationalOrganization", "NGO"],
      "name": "Association d'Alphabétisation de Fatima",
      "alternateName": lang === "en" ? "Fatima Literacy Association" : "Association d'Alphabétisation de Fatima",
      "url": "https://association-alphabetisation-fatima.pages.dev/",
      "logo": "https://association-alphabetisation-fatima.pages.dev/images/logo-fatima-hq.webp",
      "foundingDate": "1989",
      "description": description,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Trou aux Biches Road",
        "addressLocality": "Triolet",
        "addressRegion": "Pamplemousses",
        "addressCountry": "MU"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": footer.phone1Link,
        "contactType": "customer support",
        "availableLanguage": ["French", "English"]
      },
      "email": footer.email,
      "sameAs": ["https://www.facebook.com/alphabetisation.fatima"],
      "areaServed": {
        "@type": "Country",
        "name": "Mauritius"
      },
      "identifier": [
        { "@type": "PropertyValue", "name": "CSR Code", "value": footer.csrCode }
      ]
    })} />
  </head>
  <body class="font-sans text-gray-700 bg-gray-50 antialiased">
    <slot />
  </body>
</html>
