---
import footerData from '../data/footer.json';

const year = new Date().getFullYear();
const addressLines = footerData.address.split('\n');
---

<footer id="contact" class="bg-brand-dark text-gray-300 pt-10 md:pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-3 gap-8 md:gap-12 mb-8 md:mb-12">
      <!-- Info -->
      <div>
        <div class="flex items-center gap-3 mb-6">
          <div class="bg-white rounded-lg p-1 flex-shrink-0">
            <img
              src="/images/logo-fatima-hq.webp"
              alt="Logo Association d'Alphabétisation de Fatima"
              class="h-10 w-auto"
              width="40"
              height="40"
            />
          </div>
          <h3 class="text-white font-bold text-lg">Association d'Alphabétisation de Fatima</h3>
        </div>
        <p class="text-sm leading-relaxed mb-6 opacity-80">
          {footerData.orgDescription}
        </p>
        <div class="space-y-2">
          <p class="text-sm font-semibold text-brand-pink">
            Présidente : {footerData.president}
          </p>
          <p class="text-sm font-semibold text-brand-light-blue">
            Directrice : {footerData.director}
          </p>
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white font-bold text-lg mb-6">{footerData.contactHeading}</h4>
        <ul class="space-y-4 text-sm">
          <li class="flex items-start">
            <i class="fas fa-map-marker-alt mt-1 mr-3 text-brand-blue"></i>
            <span>{addressLines.map((line, i) => <>{i > 0 && <br />}{line}</>)}</span>
          </li>
          <li class="flex items-center">
            <i class="fas fa-phone mr-3 text-brand-blue"></i>
            <a href={`tel:${footerData.phone1Link}`} class="hover:text-white transition"
              >{footerData.phone1}</a
            >
          </li>
          <li class="flex items-center">
            <i class="fas fa-phone mr-3 text-brand-blue"></i>
            <a href={`tel:${footerData.phone2Link}`} class="hover:text-white transition"
              >{footerData.phone2}</a
            >
          </li>
          <li class="flex items-center">
            <i class="fas fa-envelope mr-3 text-brand-blue"></i>
            <a
              href={`mailto:${footerData.email}`}
              class="hover:text-white transition">{footerData.email}</a
            >
          </li>
        </ul>
      </div>

      <!-- Accreditation -->
      <div>
        <h4 class="text-white font-bold text-lg mb-6">{footerData.transparencyHeading}</h4>
        <div class="bg-gray-800 p-4 rounded-lg border border-gray-700">
          <p class="text-xs text-gray-400 mb-2 uppercase tracking-wide">
            Accréditations Officielles
          </p>
          <ul class="space-y-2 text-sm">
            <li class="flex justify-between">
              <span>Reg. ONG:</span>
              <span class="text-white font-mono">{footerData.ngoRegistered}</span>
            </li>
            <li class="flex justify-between">
              <span>NSIF Code:</span>
              <span class="text-white font-mono">{footerData.nsifCode}</span>
            </li>
            <li class="flex justify-between">
              <span>CSR Code:</span>
              <span class="text-white font-mono">{footerData.csrCode}</span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="border-t border-gray-700 pt-8 text-center text-sm text-gray-500">
      <p>
        &copy; {year} {footerData.copyright}
      </p>
    </div>
  </div>
</footer>
