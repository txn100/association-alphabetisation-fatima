---
import impactData from '../data/impact.json';
---

<section class="relative h-64 md:h-80 overflow-hidden">
  <div class="absolute inset-0 grid grid-cols-3">
    {impactData.images.map((img) => (
      <img src={img.src} alt={img.alt} class="w-full h-full object-cover" loading="lazy" decoding="async" />
    ))}
  </div>
  <div class="absolute inset-0 bg-gradient-to-r from-brand-blue/85 via-brand-dark/70 to-brand-pink/85 flex items-center justify-center">
    <div class="text-center px-4">
      <p class="text-white/80 text-sm uppercase tracking-widest font-bold mb-3">{impactData.sinceLabel}</p>
      <h3 class="font-heading text-2xl sm:text-3xl md:text-4xl font-extrabold text-white mb-4">
        {impactData.headline}
      </h3>
      <p class="text-white/90 max-w-xl mx-auto text-sm md:text-base">
        {impactData.description}
      </p>
    </div>
  </div>
</section>
