---
/**
 * Shared page renderer for FR and EN.
 * Receives locale, UI strings, and all content data as props.
 */
import Layout from "../layouts/Layout.astro";
import type { Locale, UIStrings } from "../lib/i18n";

// React visual editing wrappers
import NavbarVisual from "./react/NavbarVisual";
import HeroVisual from "./react/HeroVisual";
import StatsVisual from "./react/StatsVisual";
import AboutVisual from "./react/AboutVisual";
import ProgramsVisual from "./react/ProgramsVisual";
import ImpactBannerVisual from "./react/ImpactBannerVisual";
import ProjectsVisual from "./react/ProjectsVisual";
import NewsVisual from "./react/NewsVisual";
import GalleryVisual from "./react/GalleryVisual";
import DonateVisual from "./react/DonateVisual";
import FooterVisual from "./react/FooterVisual";

interface Props {
  lang: Locale;
  ui: UIStrings;
  siteData: any;
  navigationData: any;
  heroData: any;
  statsData: any;
  statsSectionData: any;
  aboutData: any;
  programsData: any;
  programsSectionData: any;
  impactData: any;
  projectsData: any;
  projectsSectionData: any;
  newsData: any;
  pedagogyData: any;
  galleryData: any;
  gallerySectionData: any;
  donateData: any;
  tiersData: any;
  footerData: any;
}

const {
  lang, ui, siteData,
  navigationData, heroData, statsData, statsSectionData,
  aboutData, programsData, programsSectionData,
  impactData, projectsData, projectsSectionData,
  newsData, pedagogyData, galleryData, gallerySectionData,
  donateData, tiersData, footerData,
} = Astro.props;

// Serialize UI strings for vanilla JS injection
const uiJson = JSON.stringify(ui);
---

<Layout
  lang={lang}
  title={siteData.data?.site?.title}
  description={siteData.data?.site?.description}
  preloadHero={true}
>
  <NavbarVisual {...navigationData} lang={lang} ui={ui} client:tina />
  <main>
    <HeroVisual {...heroData} client:tina />
    <StatsVisual
      {...statsData}
      sectionData={statsSectionData.data}
      sectionQuery={statsSectionData.query}
      sectionVariables={statsSectionData.variables}
      client:tina
    />
    <AboutVisual {...aboutData} client:tina />
    <ProgramsVisual
      {...programsData}
      sectionData={programsSectionData.data}
      sectionQuery={programsSectionData.query}
      sectionVariables={programsSectionData.variables}
      lang={lang}
      ui={ui}
      client:tina
    />
    <ImpactBannerVisual {...impactData} client:tina />
    <ProjectsVisual
      {...projectsData}
      sectionData={projectsSectionData.data}
      sectionQuery={projectsSectionData.query}
      sectionVariables={projectsSectionData.variables}
      lang={lang}
      ui={ui}
      client:tina
    />
    <NewsVisual
      {...newsData}
      sectionData={pedagogyData.data}
      sectionQuery={pedagogyData.query}
      sectionVariables={pedagogyData.variables}
      lang={lang}
      ui={ui}
      client:tina
    />
    <GalleryVisual
      {...galleryData}
      sectionData={gallerySectionData.data}
      sectionQuery={gallerySectionData.query}
      sectionVariables={gallerySectionData.variables}
      client:tina
    />
    <DonateVisual
      {...donateData}
      tiersData={tiersData.data}
      tiersQuery={tiersData.query}
      tiersVariables={tiersData.variables}
      footerData={footerData.data}
      footerQuery={footerData.query}
      footerVariables={footerData.variables}
      lang={lang}
      ui={ui}
      client:tina
    />
  </main>
  <FooterVisual {...footerData} lang={lang} ui={ui} client:tina />

  <!-- Hidden element to pass contact data to vanilla JS -->
  <div id="contact-meta" hidden
    data-whatsapp={footerData.data.footer.whatsappNumber}
    data-email={footerData.data.footer.email}
    data-phone1={footerData.data.footer.phone1}
    data-phone1-link={footerData.data.footer.phone1Link}
    data-phone2={footerData.data.footer.phone2}
    data-phone2-link={footerData.data.footer.phone2Link}
    data-phone3={footerData.data.footer.phone3}
    data-phone3-link={footerData.data.footer.phone3Link}
  ></div>

  <!-- Vanilla JS for interactive elements (client:tina doesn't hydrate on production) -->
  <script define:vars={{ lang, uiJson }}>
    window.__lang = lang;
    window.__uiStrings = JSON.parse(uiJson);
  </script>

  <script>
    if (window.self === window.top) {
      const ui = (window as any).__uiStrings || {};

      // === MOBILE MENU TOGGLE ===
      const menuBtn = document.getElementById("mobile-menu-btn");
      const menuPanel = document.getElementById("mobile-menu-panel");
      if (menuBtn && menuPanel) {
        menuBtn.addEventListener("click", () => {
          const isOpen = !menuPanel.classList.contains("hidden");
          menuPanel.classList.toggle("hidden", isOpen);
          menuBtn.setAttribute("aria-expanded", String(!isOpen));
        });
        menuPanel.querySelectorAll(".mobile-nav-link").forEach((link) => {
          link.addEventListener("click", () => {
            menuPanel.classList.add("hidden");
            menuBtn.setAttribute("aria-expanded", "false");
          });
        });
        window.addEventListener("scroll", () => {
          if (!menuPanel.classList.contains("hidden")) {
            menuPanel.classList.add("hidden");
            menuBtn.setAttribute("aria-expanded", "false");
          }
        }, { passive: true });
      }

      // === SMOOTH SCROLL for anchor links ===
      document.querySelectorAll('a[href^="#"]').forEach((link) => {
        link.addEventListener("click", (e) => {
          const href = (link as HTMLAnchorElement).getAttribute("href");
          if (!href || href === "#") return;
          const target = document.querySelector(href);
          if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: "smooth" });
          }
        });
      });

      // === DONATE TAB SWITCHING ===
      const tabBtns = document.querySelectorAll("[data-tab-btn]");
      const tabContents = document.querySelectorAll("[data-tab-content]");
      tabBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          const tab = (btn as HTMLElement).dataset.tabBtn;
          tabBtns.forEach((b) => {
            const bTab = (b as HTMLElement).dataset.tabBtn;
            b.setAttribute("aria-selected", String(bTab === tab));
            if (bTab === tab) {
              b.className = b.className
                .replace("text-gray-500 hover:text-gray-700", "")
                .replace("bg-brand-blue text-white shadow-sm", "")
                .replace("bg-brand-pink text-white shadow-sm", "")
                + (bTab === "don" ? " bg-brand-blue text-white shadow-sm" : " bg-brand-pink text-white shadow-sm");
            } else {
              b.className = b.className
                .replace("bg-brand-blue text-white shadow-sm", "")
                .replace("bg-brand-pink text-white shadow-sm", "")
                + " text-gray-500 hover:text-gray-700";
            }
          });
          tabContents.forEach((content) => {
            const cTab = (content as HTMLElement).dataset.tabContent;
            content.classList.toggle("hidden", cTab !== tab);
          });
        });
      });

      // === ACCOUNT TYPE TOGGLE (Particulier / Entreprise CSR) ===
      const accountBtns = document.querySelectorAll<HTMLButtonElement>("[data-account-btn]");
      const accountNumEl = document.querySelector<HTMLElement>("[data-account-num]");
      if (accountBtns.length && accountNumEl) {
        accountBtns.forEach((btn) => {
          btn.addEventListener("click", () => {
            const tab = btn.dataset.accountBtn;
            accountNumEl.textContent = tab === "csr"
              ? (accountNumEl.dataset.csr || "")
              : (accountNumEl.dataset.private || "");
            accountBtns.forEach((b) => {
              const isActive = b.dataset.accountBtn === tab;
              b.classList.toggle("bg-white", isActive);
              b.classList.toggle("text-brand-blue", isActive);
              b.classList.toggle("shadow-sm", isActive);
              b.classList.toggle("text-gray-500", !isActive);
              b.classList.toggle("hover:text-gray-700", !isActive);
            });
          });
        });
      }

      // === PARRAIN FORM: WhatsApp & Email send ===
      const parrainForm = document.getElementById("parrain-form") as HTMLFormElement | null;
      if (parrainForm) {
        const contactMeta = document.getElementById("contact-meta");
        const waNumber = contactMeta?.dataset.whatsapp || "23059855253";
        const contactEmail = contactMeta?.dataset.email || "direction@ecolefatima.com";

        const getFormData = () => {
          const fd = new FormData(parrainForm);
          const nom = fd.get("nom") as string;
          const email = fd.get("email") as string;
          const tel = fd.get("telephone") || (ui.formPhoneNotProvided || "Non renseigné");
          const selectEl = parrainForm.querySelector("select") as HTMLSelectElement;
          const formule = selectEl?.selectedOptions[0]?.text || "";
          const msg = fd.get("message") || (ui.formMessageEmpty || "(aucun)");
          return { nom, email, tel, formule, msg };
        };

        // WhatsApp button
        const waBtn = parrainForm.querySelector('[data-send="whatsapp"]');
        if (waBtn) {
          waBtn.addEventListener("click", (e) => {
            e.preventDefault();
            const { nom, email, tel, formule, msg } = getFormData();
            if (!nom || !email) { parrainForm.reportValidity(); return; }
            const text = encodeURIComponent(
              `${ui.formGreeting || "Bonjour,"}\n\n${ui.formIntro || "Je souhaite devenir parrain."}\n\n${ui.formNameLabel || "Nom"} : ${nom}\n${ui.formEmailLabel || "Email"} : ${email}\n${ui.formPhoneLabel || "Téléphone"} : ${tel}\n${ui.formFormulaLabel || "Formule"} : ${formule}\n\n${ui.formMessageLabel || "Message"} : ${msg}`
            );
            window.open(`https://wa.me/${waNumber}?text=${text}`, "_blank");
          });
        }

        // Email button (form submit)
        parrainForm.addEventListener("submit", (e) => {
          e.preventDefault();
          const { nom, email, tel, formule, msg } = getFormData();
          if (!nom || !email) { parrainForm.reportValidity(); return; }
          const subject = encodeURIComponent(`${ui.formSubjectPrefix || "Demande de Parrainage"} — ${nom}`);
          const body = encodeURIComponent(
            `${ui.formGreeting || "Bonjour,"}\n\n${ui.formIntro || "Je souhaite devenir parrain."}\n\n${ui.formNameLabel || "Nom"} : ${nom}\n${ui.formEmailLabel || "Email"} : ${email}\n${ui.formPhoneLabel || "Téléphone"} : ${tel}\n${ui.formFormulaLabel || "Formule"} : ${formule}\n\n${ui.formMessageLabel || "Message"} :\n${msg}\n\n${ui.formClosing || "Cordialement"}`
          );
          window.location.href = `mailto:${contactEmail}?subject=${subject}&body=${body}`;
        });
      }
    }
  </script>
</Layout>
