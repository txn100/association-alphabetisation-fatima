---
import { getCollection } from 'astro:content';
import statsSection from '../data/stats-section.json';

const statsEntries = await getCollection('stats');
const stats = statsEntries
  .sort((a, b) => a.data.order - b.data.order)
  .map(entry => ({ value: entry.data.value, label: entry.data.label }));

const badgeIcons = [
  "fas fa-check-circle text-green-500",
  "fas fa-certificate text-brand-blue",
  "fas fa-hand-holding-heart text-brand-yellow",
  "fas fa-shield-alt text-brand-pink",
  "fas fa-award text-brand-blue",
];
---

<section class="py-8 md:py-12 bg-brand-light -mt-2 relative z-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div
      class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8 text-center md:divide-x md:divide-gray-200"
    >
      {
        stats.map((stat) => (
          <div class="p-3 md:p-4">
            <div class="text-2xl sm:text-3xl font-heading font-extrabold text-brand-blue mb-1">
              {stat.value}
            </div>
            <div class="text-xs sm:text-sm font-semibold text-gray-500 uppercase tracking-wide">
              {stat.label}
            </div>
          </div>
        ))
      }
    </div>

    <!-- Accreditation Badges -->
    <div class="mt-8 md:mt-12 flex flex-wrap justify-center gap-3 md:gap-4 text-center">
      {
        statsSection.badges.map((badge, i) => (
          <span class="inline-flex items-center px-4 py-2 rounded-full border border-gray-300 bg-white text-sm font-medium text-gray-600 shadow-sm">
            <i class={`${badgeIcons[i] || badgeIcons[0]} mr-2`} />
            {badge.label}
          </span>
        ))
      }
    </div>
  </div>
</section>
