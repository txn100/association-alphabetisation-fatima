---
import { getCollection } from 'astro:content';
import gallerySection from '../data/gallery-section.json';

const galleryEntries = await getCollection('gallery');
const photos = galleryEntries
  .sort((a, b) => a.data.order - b.data.order)
  .map(entry => entry.data);
---

<section id="galerie" class="py-12 md:py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-8 md:mb-12">
      <h2 class="font-heading text-2xl sm:text-3xl font-bold text-gray-800 mb-3">
        {gallerySection.heading} <span class="text-brand-pink">{gallerySection.headingHighlight}</span>
      </h2>
      <p class="text-gray-600 max-w-xl mx-auto">
        {gallerySection.description}
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-2 md:gap-3 auto-rows-[140px] sm:auto-rows-[160px] md:auto-rows-[180px]">
      {
        photos.map((photo) => (
          <div class={`overflow-hidden rounded-xl group ${photo.span}`}>
            <img
              src={photo.src}
              alt={photo.alt}
              class="w-full h-full object-cover group-hover:scale-105 transition duration-500"
              loading="lazy"
              decoding="async"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>
