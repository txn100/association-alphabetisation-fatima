---
const links = [
  { href: "#accueil", label: "Accueil" },
  { href: "#apropos", label: "Notre Histoire" },
  { href: "#parcours", label: "Le Parcours" },
  { href: "#pedagogie", label: "Pédagogie" },
  { href: "#galerie", label: "Galerie" },
];
---

<nav
  class="bg-white shadow-md fixed w-full z-50 transition-all duration-300"
  id="navbar"
  aria-label="Navigation principale"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-14 sm:h-16 md:h-20 items-center">
      <!-- Logo -->
      <a href="#accueil" class="flex-shrink-0 flex items-center gap-2">
        <img
          src="/images/logo-fatima-hq.jpg"
          alt="Logo Association d'Alphabétisation de Fatima"
          class="h-10 sm:h-14 md:h-16 w-auto mix-blend-multiply"
          width="64"
          height="64"
        />
        <span class="font-heading font-bold text-brand-blue leading-tight text-[11px] sm:text-sm md:text-base"
          >Association d'Alphabétisation<br class="hidden lg:block" /> de Fatima</span
        >
      </a>

      <!-- Desktop Menu -->
      <div class="hidden md:flex space-x-8 items-center">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="text-gray-600 hover:text-brand-blue font-semibold transition"
            >
              {link.label}
            </a>
          ))
        }
        <a
          href="#faire-un-don"
          class="bg-brand-pink hover:bg-pink-600 text-white px-5 py-2 rounded-full font-bold shadow-sm transition transform hover:scale-105"
        >
          <i class="fas fa-heart mr-2"></i> Devenir Parrain
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden text-gray-600 hover:text-brand-blue focus:outline-none p-2 -mr-2"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Ouvrir le menu"
      >
        <i class="fas fa-bars text-2xl"></i>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Panel -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-white border-t border-gray-100 absolute w-full shadow-lg"
  >
    <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="block px-3 py-3 rounded-md text-base font-medium text-gray-700 hover:text-brand-blue hover:bg-gray-50"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="#faire-un-don"
        class="block px-3 py-3 mt-4 text-center rounded-md text-base font-bold bg-brand-pink text-white"
      >
        Devenir Parrain
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById("mobile-menu-btn")!;
  const menu = document.getElementById("mobile-menu")!;

  btn.addEventListener("click", () => {
    const isOpen = !menu.classList.contains("hidden");
    menu.classList.toggle("hidden");
    btn.setAttribute("aria-expanded", String(!isOpen));
  });

  // Close mobile menu when clicking a link
  menu.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      btn.setAttribute("aria-expanded", "false");
    });
  });

  // Close mobile menu on scroll
  window.addEventListener(
    "scroll",
    () => {
      if (!menu.classList.contains("hidden")) {
        menu.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
      }
    },
    { passive: true },
  );

  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener("click", (e) => {
      e.preventDefault();
      const href = (e.currentTarget as HTMLAnchorElement).getAttribute("href");
      if (href) {
        document.querySelector(href)?.scrollIntoView({ behavior: "smooth" });
      }
    });
  });

  // Navbar scroll effect
  const navbar = document.getElementById("navbar")!;
  window.addEventListener(
    "scroll",
    () => {
      if (window.scrollY > 50) {
        navbar.classList.add("backdrop-blur-sm");
        navbar.style.backgroundColor = "rgba(255,255,255,0.95)";
      } else {
        navbar.classList.remove("backdrop-blur-sm");
        navbar.style.backgroundColor = "";
      }
    },
    { passive: true },
  );
</script>
