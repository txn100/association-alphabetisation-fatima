---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import siteData from '../../data/site.json';
import footerData from '../../data/footer.json';

const newsEntries = await getCollection('news');
const news = newsEntries.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).map(e => ({ ...e.data, slug: e.data.slug || e.id }));

const pageTitle = `Actualités — ${siteData.organizationName}`;
const pageDescription = "Dernières nouvelles de l'Association d'Alphabétisation de Fatima : événements, sorties scolaires, spectacles et activités pédagogiques.";
const canonicalPath = '/actualites/';

const categoryColors: Record<string, string> = {
  'Formation': 'bg-brand-blue text-white',
  'Culture': 'bg-brand-pink text-white',
  'Vie Scolaire': 'bg-brand-yellow text-brand-dark',
  'Environnement': 'bg-green-500 text-white',
};
---

<Layout lang="fr" title={pageTitle} description={pageDescription} canonicalPath={canonicalPath}>
  <!-- Navbar -->
  <nav class="bg-white shadow-sm sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3 group">
        <img
          src="/images/logo-fatima-hq.webp"
          alt={`Logo ${siteData.organizationName}`}
          class="h-10 w-auto"
          width="40"
          height="40"
          loading="eager"
        />
        <span class="navbar-title font-heading font-bold text-brand-dark uppercase tracking-wide hidden sm:block">
          {siteData.organizationName}
        </span>
      </a>
      <div class="flex items-center gap-2">
        <a href="/en/news/" class="text-xs font-bold border border-brand-blue text-brand-blue px-3 py-1.5 rounded-full hover:bg-brand-blue hover:text-white transition" hreflang="en">EN</a>
        <a
          href="/#faire-un-don"
          class="inline-flex items-center gap-2 bg-brand-pink hover:bg-pink-600 text-white font-heading font-bold text-sm px-5 py-2.5 rounded-full transition-colors shadow-md"
        >
          <i class="fas fa-heart text-xs"></i>
          Soutenir
        </a>
      </div>
    </div>
  </nav>

  <main>
    <!-- Breadcrumb -->
    <div class="bg-gray-100 border-b border-gray-200">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
        <nav aria-label="Fil d'Ariane" class="text-sm text-gray-500">
          <ol class="flex items-center gap-1.5 flex-wrap">
            <li><a href="/" class="hover:text-brand-blue transition-colors">Accueil</a></li>
            <li aria-hidden="true"><i class="fas fa-chevron-right text-[10px] text-gray-400 mx-1"></i></li>
            <li class="text-brand-dark font-semibold" aria-current="page">Actualités</li>
          </ol>
        </nav>
      </div>
    </div>

    <!-- Header -->
    <div class="bg-brand-dark text-white py-12 sm:py-16">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="font-heading text-3xl sm:text-4xl font-extrabold mb-3">Actualités</h1>
        <p class="text-blue-100 text-lg max-w-2xl">
          Événements, sorties et moments forts de la vie de l'école.
        </p>
      </div>
    </div>

    <!-- News Grid -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {news.map((item) => (
          <article class="bg-white rounded-2xl shadow-md overflow-hidden border border-gray-100 hover:shadow-lg transition-shadow group">
            {item.image && (
              <a href={`/actualites/${item.slug}`} class="block overflow-hidden">
                <img
                  src={item.image}
                  alt={item.imageAlt || item.title}
                  class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            )}
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <time datetime={item.date} class="text-xs text-gray-400 font-semibold">
                  {item.day} {item.month} {item.year}
                </time>
                <span class={`text-xs font-bold px-2 py-0.5 rounded-full ${categoryColors[item.category] || 'bg-gray-200 text-gray-700'}`}>
                  {item.category}
                </span>
              </div>
              <h2 class="font-heading text-lg font-bold text-gray-800 mb-2 group-hover:text-brand-blue transition-colors">
                <a href={`/actualites/${item.slug}`}>{item.title}</a>
              </h2>
              {item.description && (
                <p class="text-gray-600 text-sm leading-relaxed line-clamp-3 mb-4">{item.description}</p>
              )}
              <a
                href={`/actualites/${item.slug}`}
                class="inline-flex items-center text-sm font-bold text-brand-blue hover:text-blue-700 transition-colors"
              >
                Lire la suite <i class="fas fa-arrow-right ml-1 text-xs"></i>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <section class="bg-brand-dark py-16">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="font-heading font-extrabold text-2xl text-white mb-4">Soutenir notre mission</h2>
        <p class="text-white/70 mb-8">Chaque don contribue directement à l'éducation de nos élèves.</p>
        <a
          href="/#faire-un-don"
          class="inline-flex items-center gap-2 bg-brand-pink hover:bg-pink-600 text-white font-heading font-bold px-8 py-3.5 rounded-full transition-colors shadow-lg"
        >
          <i class="fas fa-heart"></i> Faire un don
        </a>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="bg-brand-dark border-t border-white/10 py-8">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-white/50 text-sm">
        <a href={`mailto:${footerData.email}`} class="hover:text-white transition-colors">{footerData.email}</a>
      </p>
      <p class="text-white/30 text-xs mt-2">
        &copy; {new Date().getFullYear()} {footerData.copyright}
      </p>
    </div>
  </footer>

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": pageTitle,
    "description": pageDescription,
    "mainEntity": {
      "@type": "ItemList",
      "itemListElement": news.map((item, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "url": `https://association-alphabetisation-fatima.pages.dev/actualites/${item.slug}`,
        "name": item.title,
      })),
    },
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://association-alphabetisation-fatima.pages.dev/" },
      { "@type": "ListItem", "position": 2, "name": "Actualités" }
    ]
  })} />
</Layout>
