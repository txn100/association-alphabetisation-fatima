---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
---

<Layout lang="fr" title="Page non trouvée — Association d'Alphabétisation de Fatima" description="La page que vous recherchez n'existe pas ou a été déplacée.">
  <main class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
    <div class="text-center max-w-md">
      <p class="text-7xl font-heading font-extrabold text-brand-blue mb-4">404</p>
      <h1 class="font-heading text-2xl font-bold text-gray-800 mb-3">Page non trouvée</h1>
      <p class="text-gray-500 mb-8">
        La page que vous recherchez n'existe pas ou a été déplacée.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 bg-brand-blue hover:bg-blue-700 text-white px-6 py-3 rounded-full font-bold transition shadow-md"
      >
        <i class="fas fa-home"></i> Retour à l'accueil
      </a>
    </div>
  </main>
</Layout>
