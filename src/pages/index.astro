---
export const prerender = true;
/**
 * French homepage (/).
 * Thin wrapper that loads FR content and delegates to the shared HomePage renderer.
 */
import HomePage from "../components/HomePage.astro";
import { uiStrings } from "../lib/i18n";
import type { Locale } from "../lib/i18n";
import {
  getStatsData, getProgramsData, getNewsData, getGalleryData, getTiersData,
  getHeroData, getAboutData, getFooterData, getNavigationData,
  getImpactData, getPedagogyData, getDonateData, getSiteData,
  getStatsSectionData, getProgramsSectionData, getGallerySectionData,
  getProjectsData, getProjectsSectionData,
} from "../lib/content";

const lang: Locale = "fr";
const ui = uiStrings[lang];

const [
  siteData, statsData, programsData, newsData, galleryData, tiersData,
  heroData, aboutData, footerData, navigationData,
  impactData, pedagogyData, donateData,
  statsSectionData, programsSectionData, gallerySectionData,
  projectsData, projectsSectionData,
] = await Promise.all([
  getSiteData(lang), getStatsData(lang), getProgramsData(lang), getNewsData(lang),
  getGalleryData(), getTiersData(lang),
  getHeroData(lang), getAboutData(lang), getFooterData(lang), getNavigationData(lang),
  getImpactData(lang), getPedagogyData(lang), getDonateData(lang),
  getStatsSectionData(lang), getProgramsSectionData(lang), getGallerySectionData(lang),
  getProjectsData(lang), getProjectsSectionData(lang),
]);
---

<HomePage
  lang={lang}
  ui={ui}
  siteData={siteData}
  navigationData={navigationData}
  heroData={heroData}
  statsData={statsData}
  statsSectionData={statsSectionData}
  aboutData={aboutData}
  programsData={programsData}
  programsSectionData={programsSectionData}
  impactData={impactData}
  projectsData={projectsData}
  projectsSectionData={projectsSectionData}
  newsData={newsData}
  pedagogyData={pedagogyData}
  galleryData={galleryData}
  gallerySectionData={gallerySectionData}
  donateData={donateData}
  tiersData={tiersData}
  footerData={footerData}
/>
