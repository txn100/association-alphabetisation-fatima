---
import Layout from "../layouts/Layout.astro";

// Visual editing React wrappers (only hydrate inside TinaCMS admin)
import NavbarVisual from "../components/react/NavbarVisual";
import HeroVisual from "../components/react/HeroVisual";
import StatsVisual from "../components/react/StatsVisual";
import AboutVisual from "../components/react/AboutVisual";
import ProgramsVisual from "../components/react/ProgramsVisual";
import ImpactBannerVisual from "../components/react/ImpactBannerVisual";
import NewsVisual from "../components/react/NewsVisual";
import GalleryVisual from "../components/react/GalleryVisual";
import DonateVisual from "../components/react/DonateVisual";
import FooterVisual from "../components/react/FooterVisual";

// Read content files directly at build time (no GraphQL server needed).
// In the TinaCMS admin iframe, React components hydrate and use
// useTina() to subscribe to live GraphQL updates for visual editing.
import {
  getStatsData, getProgramsData, getNewsData, getGalleryData, getTiersData,
  getHeroData, getAboutData, getFooterData, getNavigationData,
  getImpactData, getPedagogyData, getDonateData,
  getStatsSectionData, getProgramsSectionData, getGallerySectionData,
} from "../lib/content";

const [
  statsData, programsData, newsData, galleryData, tiersData,
  heroData, aboutData, footerData, navigationData,
  impactData, pedagogyData, donateData,
  statsSectionData, programsSectionData, gallerySectionData,
] = await Promise.all([
  getStatsData(), getProgramsData(), getNewsData(), getGalleryData(), getTiersData(),
  getHeroData(), getAboutData(), getFooterData(), getNavigationData(),
  getImpactData(), getPedagogyData(), getDonateData(),
  getStatsSectionData(), getProgramsSectionData(), getGallerySectionData(),
]);
---

<Layout>
  <NavbarVisual {...navigationData} client:tina />
  <main>
    <HeroVisual {...heroData} client:tina />
    <StatsVisual
      {...statsData}
      sectionData={statsSectionData.data}
      sectionQuery={statsSectionData.query}
      sectionVariables={statsSectionData.variables}
      client:tina
    />
    <AboutVisual {...aboutData} client:tina />
    <ProgramsVisual
      {...programsData}
      sectionData={programsSectionData.data}
      sectionQuery={programsSectionData.query}
      sectionVariables={programsSectionData.variables}
      client:tina
    />
    <ImpactBannerVisual {...impactData} client:tina />
    <NewsVisual
      {...newsData}
      sectionData={pedagogyData.data}
      sectionQuery={pedagogyData.query}
      sectionVariables={pedagogyData.variables}
      client:tina
    />
    <GalleryVisual
      {...galleryData}
      sectionData={gallerySectionData.data}
      sectionQuery={gallerySectionData.query}
      sectionVariables={gallerySectionData.variables}
      client:tina
    />
    <DonateVisual
      {...donateData}
      tiersData={tiersData.data}
      tiersQuery={tiersData.query}
      tiersVariables={tiersData.variables}
      client:tina
    />
  </main>
  <FooterVisual {...footerData} client:tina />
</Layout>

<!-- Vanilla JS for interactive elements (client:tina doesn't hydrate on production) -->
<script>
  // Skip if inside TinaCMS admin iframe (React handles everything there)
  if (window.self === window.top) {
    // === MOBILE MENU TOGGLE ===
    const menuBtn = document.getElementById("mobile-menu-btn");
    const menuPanel = document.getElementById("mobile-menu-panel");
    if (menuBtn && menuPanel) {
      menuBtn.addEventListener("click", () => {
        const isOpen = !menuPanel.classList.contains("hidden");
        menuPanel.classList.toggle("hidden", isOpen);
        menuBtn.setAttribute("aria-expanded", String(!isOpen));
      });
      // Close menu when a nav link is clicked
      menuPanel.querySelectorAll(".mobile-nav-link").forEach((link) => {
        link.addEventListener("click", () => {
          menuPanel.classList.add("hidden");
          menuBtn.setAttribute("aria-expanded", "false");
        });
      });
      // Close menu on scroll
      window.addEventListener("scroll", () => {
        if (!menuPanel.classList.contains("hidden")) {
          menuPanel.classList.add("hidden");
          menuBtn.setAttribute("aria-expanded", "false");
        }
      }, { passive: true });
    }

    // === SMOOTH SCROLL for anchor links ===
    document.querySelectorAll('a[href^="#"]').forEach((link) => {
      link.addEventListener("click", (e) => {
        const href = (link as HTMLAnchorElement).getAttribute("href");
        if (!href || href === "#") return;
        const target = document.querySelector(href);
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: "smooth" });
        }
      });
    });

    // === DONATE TAB SWITCHING ===
    const tabBtns = document.querySelectorAll("[data-tab-btn]");
    const tabContents = document.querySelectorAll("[data-tab-content]");
    tabBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const tab = (btn as HTMLElement).dataset.tabBtn;
        // Update button styles
        tabBtns.forEach((b) => {
          const bTab = (b as HTMLElement).dataset.tabBtn;
          if (bTab === tab) {
            b.className = b.className
              .replace("text-gray-500 hover:text-gray-700", "")
              .replace("bg-brand-blue text-white shadow-sm", "")
              .replace("bg-brand-pink text-white shadow-sm", "")
              + (bTab === "don" ? " bg-brand-blue text-white shadow-sm" : " bg-brand-pink text-white shadow-sm");
          } else {
            b.className = b.className
              .replace("bg-brand-blue text-white shadow-sm", "")
              .replace("bg-brand-pink text-white shadow-sm", "")
              + " text-gray-500 hover:text-gray-700";
          }
        });
        // Show/hide tab content
        tabContents.forEach((content) => {
          const cTab = (content as HTMLElement).dataset.tabContent;
          content.classList.toggle("hidden", cTab !== tab);
        });
      });
    });

    // === PARRAIN FORM: WhatsApp & Email send ===
    const parrainForm = document.getElementById("parrain-form") as HTMLFormElement | null;
    if (parrainForm) {
      const getFormData = () => {
        const fd = new FormData(parrainForm);
        const nom = fd.get("nom") as string;
        const email = fd.get("email") as string;
        const tel = fd.get("telephone") || "Non renseigné";
        const selectEl = parrainForm.querySelector("select") as HTMLSelectElement;
        const formule = selectEl?.selectedOptions[0]?.text || "";
        const msg = fd.get("message") || "(aucun)";
        return { nom, email, tel, formule, msg };
      };

      // WhatsApp button
      const waBtn = parrainForm.querySelector('[data-send="whatsapp"]');
      if (waBtn) {
        waBtn.addEventListener("click", (e) => {
          e.preventDefault();
          const { nom, email, tel, formule, msg } = getFormData();
          if (!nom || !email) { parrainForm.reportValidity(); return; }
          const text = encodeURIComponent(
            `Bonjour,\n\nJe souhaite devenir parrain.\n\nNom : ${nom}\nEmail : ${email}\nTéléphone : ${tel}\nFormule : ${formule}\n\nMessage : ${msg}`
          );
          window.open(`https://wa.me/23052611030?text=${text}`, "_blank");
        });
      }

      // Email button (form submit)
      parrainForm.addEventListener("submit", (e) => {
        e.preventDefault();
        const { nom, email, tel, formule, msg } = getFormData();
        if (!nom || !email) { parrainForm.reportValidity(); return; }
        const subject = encodeURIComponent(`Demande de Parrainage — ${nom}`);
        const body = encodeURIComponent(
          `Bonjour,\n\nJe souhaite devenir parrain.\n\nNom : ${nom}\nEmail : ${email}\nTéléphone : ${tel}\nFormule : ${formule}\n\nMessage :\n${msg}\n\nCordialement`
        );
        window.location.href = `mailto:direction@ecolefatima.com?subject=${subject}&body=${body}`;
      });
    }
  }
</script>
