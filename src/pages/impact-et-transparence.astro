---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import { uiStrings } from '../lib/i18n';
import { getCollection } from 'astro:content';

const footerModule = await import('../data/footer.json');
const footer = footerModule.default || footerModule;

const siteModule = await import('../data/site.json');
const site = siteModule.default || siteModule;

const statsEntries = await getCollection('stats');
const stats = statsEntries
  .sort((a, b) => a.data.order - b.data.order)
  .map((e) => e.data);
---

<Layout
  lang="fr"
  title={`Impact & Transparence — ${site.organizationName}`}
  description={`Chiffres clés, accréditations (CSR ${footer.csrCode}) et informations de transparence de l'Association d'Alphabétisation de Fatima, ONG enregistrée à Maurice.`}
  canonicalPath="/impact-et-transparence/"
>
  <!-- Simple Navbar -->
  <nav class="bg-white shadow-md fixed w-full z-50" aria-label="Navigation principale">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-14 sm:h-16 items-center">
        <a href="/" class="flex items-center gap-2">
          <img
            src="/images/logo-fatima-hq.webp"
            alt={`Logo ${site.organizationName}`}
            class="h-10 w-auto mix-blend-multiply"
            width="40"
            height="40"
          />
          <span class="font-heading font-bold text-brand-blue text-sm hidden sm:block">
            {site.organizationName}
          </span>
        </a>
        <div class="flex items-center gap-2">
          <a href="/en/impact-transparency/" class="text-xs font-bold border border-brand-blue text-brand-blue px-3 py-1.5 rounded-full hover:bg-brand-blue hover:text-white transition" hreflang="en">EN</a>
          <a
            href="/#faire-un-don"
            class="bg-brand-pink hover:bg-pink-600 text-white px-4 py-2 rounded-full font-bold text-sm transition"
          >
            <i class="fas fa-heart mr-1"></i> Soutenir
          </a>
        </div>
      </div>
    </div>
  </nav>

  <main class="pt-14 sm:pt-16">
    <!-- Breadcrumb -->
    <div class="bg-gray-50 border-b border-gray-200 py-3">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <nav aria-label="Fil d'Ariane" class="text-sm text-gray-500">
          <a href="/" class="hover:text-brand-blue transition">Accueil</a>
          <span class="mx-2">&rsaquo;</span>
          <span class="text-gray-800 font-semibold">Impact &amp; Transparence</span>
        </nav>
      </div>
    </div>

    <!-- Dark Header -->
    <div class="bg-brand-dark text-white py-12 sm:py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="font-heading text-3xl sm:text-4xl font-bold mb-3">
          Impact &amp; Transparence
        </h1>
        <p class="text-blue-100 text-lg max-w-2xl">
          Chiffres clés, accréditations officielles et informations de gouvernance de l'association.
        </p>
      </div>
    </div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-12">
      <!-- Stats Grid (4 stats, sorted by order) -->
      <section>
        <h2 class="font-heading text-2xl font-bold text-gray-800 mb-6">
          Nos Chiffres Clés
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {stats.map((stat) => (
            <div class="bg-white rounded-2xl shadow-md p-6 text-center border border-gray-100">
              <p class="font-heading text-3xl font-bold text-brand-blue mb-1">
                {stat.value}
              </p>
              <p class="text-sm text-gray-500">{stat.label}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Accreditations Table -->
      <section>
        <h2 class="font-heading text-2xl font-bold text-gray-800 mb-6">
          Accréditations &amp; Enregistrements
        </h2>
        <div class="bg-white rounded-2xl shadow-md overflow-hidden">
          <table class="w-full text-sm">
            <tbody>
              <tr class="border-b border-gray-100">
                <td class="px-6 py-4 font-semibold text-gray-700 w-1/2">ONG enregistrée</td>
                <td class="px-6 py-4 text-gray-600">
                  <span class="inline-flex items-center gap-2">
                    <i class="fas fa-check-circle text-green-500"></i> {footer.ngoRegistered}
                  </span>
                </td>
              </tr>
              <tr class="border-b border-gray-100 bg-gray-50">
                <td class="px-6 py-4 font-semibold text-gray-700">
                  Code CSR (Corporate Social Responsibility)
                </td>
                <td class="px-6 py-4 font-mono font-bold text-brand-blue">
                  {footer.csrCode}
                </td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="px-6 py-4 font-semibold text-gray-700">Affiliée ANFEN</td>
                <td class="px-6 py-4 text-gray-600">
                  <span class="inline-flex items-center gap-2">
                    <i class="fas fa-check-circle text-green-500"></i> Oui
                  </span>
                </td>
              </tr>
              <tr>
                <td class="px-6 py-4 font-semibold text-gray-700">Fondée en</td>
                <td class="px-6 py-4 text-gray-600">1989</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Governance -->
      <section>
        <h2 class="font-heading text-2xl font-bold text-gray-800 mb-6">
          Gouvernance
        </h2>
        <div class="grid sm:grid-cols-2 gap-6">
          <div class="bg-white rounded-2xl shadow-md p-6 border border-gray-100">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 bg-brand-blue rounded-full flex items-center justify-center flex-shrink-0">
                <i class="fas fa-user text-white text-sm"></i>
              </div>
              <div>
                <p class="font-bold text-gray-800">{footer.president}</p>
                <p class="text-sm text-gray-500">{uiStrings.fr.presidentLabel}</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-2xl shadow-md p-6 border border-gray-100">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 bg-brand-pink rounded-full flex items-center justify-center flex-shrink-0">
                <i class="fas fa-user text-white text-sm"></i>
              </div>
              <div>
                <p class="font-bold text-gray-800">{footer.director}</p>
                <p class="text-sm text-gray-500">{uiStrings.fr.directorLabel}</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Contact Info -->
      <section>
        <h2 class="font-heading text-2xl font-bold text-gray-800 mb-6">
          Contact
        </h2>
        <div class="bg-white rounded-2xl shadow-md p-8 border border-gray-100">
          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <p class="text-sm text-gray-500 mb-1">Adresse</p>
              <p class="text-gray-800 font-semibold whitespace-pre-line">
                {footer.address}
              </p>
            </div>
            <div class="space-y-3">
              <div>
                <p class="text-sm text-gray-500 mb-1">Téléphone</p>
                <a
                  href={`tel:${footer.phone1Link}`}
                  class="text-brand-blue font-semibold hover:underline"
                >
                  {footer.phone1}
                </a>
              </div>
              <div>
                <p class="text-sm text-gray-500 mb-1">Email</p>
                <a
                  href={`mailto:${footer.email}`}
                  class="text-brand-blue font-semibold hover:underline"
                >
                  {footer.email}
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="/#faire-un-don"
          class="inline-flex items-center justify-center bg-brand-pink hover:bg-pink-600 text-white px-8 py-3 rounded-full font-bold shadow-md transition transform hover:scale-105"
        >
          <i class="fas fa-heart mr-2"></i> Faire un don
        </a>
        <a
          href="/notre-histoire/"
          class="inline-flex items-center justify-center border-2 border-brand-blue text-brand-blue hover:bg-brand-blue hover:text-white px-8 py-3 rounded-full font-bold transition"
        >
          <i class="fas fa-book mr-2"></i> Notre Histoire
        </a>
      </div>
    </div>
  </main>

  <!-- Minimal Footer -->
  <footer class="bg-brand-dark text-white py-8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gray-400 text-sm">
        &copy; {footer.copyright}<br />
        <a href={`mailto:${footer.email}`} class="hover:text-white transition">{footer.email}</a>
      </p>
    </div>
  </footer>

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": `Impact & Transparence — ${site.organizationName}`,
    "description": `Chiffres clés, accréditations et informations de transparence de l'Association d'Alphabétisation de Fatima.`,
    "mainEntity": {
      "@type": "NGO",
      "name": site.organizationName,
      "foundingDate": "1989",
      "identifier": [
        { "@type": "PropertyValue", "name": "CSR Code", "value": footer.csrCode }
      ]
    }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://association-alphabetisation-fatima.pages.dev/" },
      { "@type": "ListItem", "position": 2, "name": "Impact & Transparence" }
    ]
  })} />
</Layout>
